  "keyFeatures": [
    "Operational event logbook with draft/publish workflow",
    "Role-based access control (administrator, operator) via Spatie Permissions",
    "NMS/EMS inventory with network, domain, and element management",
    "CSV import rules with execution history and rollback",
    "SAP-like technical locations and equipment hierarchy",
    "External ticket/folio reference validation with regex patterns",
    "PM matrix (work order class / activity class)",
    "WYSIWYG rich-text editor with image attachments",
    "Public timeline with configurable public access",
    "Rate-limited REST API with Laravel Sanctum session authentication"
  ],
  "publicApiSurface": [
